# Non-sensitive defaults. Secrets go in `secrets/*.txt` (see secrets/README.md).
MCP_VERSION=latest
MCP_HOST=x-api.produtoramaxvision.com.br
MCP_PORT=3000
LOG_LEVEL=info
POSTGRES_USER=mcp
POSTGRES_DB=x_mcp
LLM_PROVIDER=grok
X_API_CLIENT_ID=
LICENSE_CHECK_ENABLED=false
LICENSE_SERVER_URL=https://x-license.produtoramaxvision.com.br
ENABLE_WEBHOOKS=true
PATCHRIGHT_HEADLESS=true
# Comma-separated allowed MCP API keys (Bearer tokens)
MCP_API_KEYS=
